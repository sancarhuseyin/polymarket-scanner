# Public endpoints.
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
PORT=5173

# Scanner behavior.
BOT_MODE=paper
POLL_INTERVAL_MS=30000
MAX_MARKETS=200
MIN_LIQUIDITY=500
MIN_VOLUME_24H=0
SPORTS_ONLY=false
NEAR_ZERO_YES_MAX_BID=0.02
MIN_BOOK_SIZE=5
MAX_SPREAD=0.03
CORRELATION_EDGE_MIN=0.04
STALE_BOOK_MS=15000

# Execution risk limits.
ORDER_NOTIONAL_USD=2
MAX_ORDER_NOTIONAL_USD=5
MAX_SETTLEMENT_RISK_USD=5
MAX_DAILY_NOTIONAL_USD=25
MAX_OPEN_ORDERS=10
SELL_YES_REQUIRES_INVENTORY=true
EXECUTION_STYLE=sell_yes
EXECUTE_BASKETS=false

# Required for live trading. Leave unset for scanning/paper mode.
LIVE_TRADING=false
CONFIRM_LIVE_TRADING=
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
